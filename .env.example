# --- Kalshi (start on DEMO, then switch to production) ---
KALSHI_USE_DEMO=true
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=/absolute/path/to/kalshi-private-key.pem

# URLs are auto-set from KALSHI_USE_DEMO; override only if needed:
# KALSHI_API_BASE_URL=https://external-api.demo.kalshi.co/trade-api/v2
# KALSHI_WS_URL=wss://external-api-ws.demo.kalshi.co/trade-api/ws/v2

# Auto-discover open weather brackets (recommended for live trading)
AUTO_DISCOVER_MARKETS=true
# single = one city; all = daily HIGH temp in every city (no rain/low/inflation)
WEATHER_DISCOVERY_SCOPE=all
# When scope=all, keep caps modest — WebSocket limit (~60 markets default)
WEATHER_SERIES_TICKER=KXHIGHTNYC
# Optional: limit cities when scope=all, e.g. KXHIGHTNYC,KXHIGHTCHI,KXHIGHTMIA
# WEATHER_SERIES_TICKERS=
# Caps — WebSocket cannot subscribe to 300+ tickers at once
WEATHER_MAX_SERIES=20
WEATHER_MAX_MARKETS=60
WEATHER_WS_SUBSCRIBE_BATCH_SIZE=20
# Optional: pin a specific event, e.g. KXHIGHNY-26MAY27
# WEATHER_EVENT_TICKER=

# Fallback when AUTO_DISCOVER_MARKETS=false or discovery finds nothing
KALSHI_MARKET_TICKER=KXHIGHNY-26MAY24-T75

# false = live Kalshi WebSocket (requires API keys above)
USE_MOCK_EXCHANGE=true

# --- Weather: nws (recommended) | open_meteo | mock ---
USE_MOCK_WEATHER=false
WEATHER_PROVIDER=nws
WEATHER_LOCATION=New York, NY (Central Park)
WEATHER_LATITUDE=40.7812
WEATHER_LONGITUDE=-73.9665
NWS_USER_AGENT=kalshi-weather-bot/0.1.0 (you@example.com)
WEATHER_STRIKE_TEMP_F=80
WEATHER_FORECAST_STD_F=3.5
WEATHER_POLL_INTERVAL_SEC=300

# --- Risk / sizing ---
BET_SIZE_DOLLARS=1.0
# Cap shares per order (e.g. cheap 3c YES won't size above 10 contracts)
MAX_CONTRACTS_PER_ORDER=10
MIN_ACCOUNT_BALANCE_DOLLARS=3.0

# --- Live order placement (production real money) ---
# Set true only when you intend to trade. API key must have order permission.
TRADING_ENABLED=false
ORDER_COOLDOWN_SEC=600
ORDER_PRICE_SLIPPAGE_CENTS=1
MAX_ORDERS_PER_SESSION=10
# best_edge = rank all signals, place top N by edge; first_signal = legacy immediate
ORDER_SELECTION_MODE=best_edge
ORDER_BATCH_DEBOUNCE_SEC=2.0
# Mock mode account balance (use your real balance when live)
MOCK_ACCOUNT_BALANCE_DOLLARS=11.0

# --- Runtime ---
LOG_LEVEL=INFO
ORDERBOOK_MOCK_INTERVAL_SEC=1.0
